---
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white pt-16 pb-8 mt-auto">
  <div class="container">
    <div class="grid grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="font-heading text-4xl text-accent mb-4 font-black">Club Rigel</div>
        <p class="opacity-70 max-w-[300px] leading-relaxed">
          Más que un club, una familia. Formando el carácter y el servicio desde {year - 10}.
        </p>
      </div>

      <!-- Links -->
      <div class="footer-nav">
        <h4 class="text-white mb-6 text-lg">Navegación</h4>
        <ul class="list-none flex flex-col gap-2">
          <li><a href="/quienes-somos" class="text-white/60 text-sm hover:text-accent transition-colors">Quiénes Somos</a></li>
          <li><a href="/historia" class="text-white/60 text-sm hover:text-accent transition-colors">Historia</a></li>
          <li><a href="/recursos" class="text-white/60 text-sm hover:text-accent transition-colors">Recursos</a></li>
          <li><a href="/contacto" class="text-white/60 text-sm hover:text-accent transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-nav">
        <h4 class="text-white mb-6 text-lg">Legal</h4>
        <ul class="list-none flex flex-col gap-2">
          <li><a href="/privacidad" class="text-white/60 text-sm hover:text-accent transition-colors">Privacidad</a></li>
          <li><a href="/terminos" class="text-white/60 text-sm hover:text-accent transition-colors">Términos</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 text-center text-sm opacity-50">
      <p>&copy; {year} Club de Conquistadores Rigel. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    .grid-cols-3 {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .max-w-\[300px\] {
      margin: 0 auto;
    }
  }
</style>
