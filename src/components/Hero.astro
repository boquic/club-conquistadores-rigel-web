---
import { Image } from 'astro:assets';
import heroBg from '../assets/fondo1.jpeg';
---

<section class="relative h-screen min-h-[600px] w-full flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute top-0 left-0 w-full h-full -z-10">
    <Image 
      src={heroBg} 
      alt="Conquistadores en la naturaleza" 
      class="w-full h-full object-cover" 
      quality="mid"
      format="webp"
    />
    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-primary/40 to-primary/60"></div>
  </div>

  <div class="container relative z-10 w-full">
    <slot />
  </div>
</section>

