---
interface Props {
  title: string;
  icon?: string;
  class?: string;
  href?: string;
}

const { title, icon, href, class: className } = Astro.props;
---

<div class={`card ${className || ''}`}>
  {icon && <div class="flex items-center justify-center w-15 h-15 bg-light rounded-xl text-primary text-5xl mb-6">{icon}</div>}
  <h3 class="text-2xl text-primary mb-4 font-bold">{title}</h3>
  <div class="text-gray-600 leading-relaxed flex-grow mb-8">
    <slot />
  </div>
  {href && (
    <a href={href} class="inline-flex items-center gap-2 font-semibold text-primary mt-auto w-fit hover:text-accent transition-colors">
      Descubrir
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
    </a>
  )}
</div>

<style>
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .card:hover::before {
    opacity: 1;
  }
</style>
