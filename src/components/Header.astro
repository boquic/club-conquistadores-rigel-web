---
import { Image } from 'astro:assets';
import rigelLogo from '../assets/rigel.png';
import conquisLogo from '../assets/conquis.svg';

const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Quienes somos', href: '/quienes-somos' },
  { name: 'Historia', href: '/historia' },
  { name: 'Recursos', href: '/recursos' },
  { name: 'Contacto', href: '/contacto' },
];
---

<header id="main-header" class="header fixed top-0 left-0 w-full z-sticky transition-all duration-500 py-6">
  <!-- Glassmorphism Background -->
  <div class="header-glass absolute inset-0 bg-white/80 backdrop-blur-xl -z-10 transition-all duration-500"></div>
  
  <div class="container flex justify-between items-center relative">
    <!-- Logo -->
    <a href="/" class="logo-link group">
      <div class="flex items-center gap-3 transition-transform duration-300 group-hover:scale-105">
        <Image 
          src={conquisLogo} 
          alt="Conquistadores" 
          class="logo-conquis h-[60px] w-auto drop-shadow-lg transition-all duration-500" 
        />
        <Image 
          src={rigelLogo} 
          alt="Club Rigel" 
          class="logo-rigel h-[70px] w-auto drop-shadow-lg transition-all duration-500" 
        />
      </div>
    </a>

    <!-- Desktop Nav: Floating Glass Pill -->
    <nav class="desktop-nav hidden lg:flex items-center gap-4">
      <ul class="glass-panel flex items-center gap-1 px-2 py-2 rounded-full list-none shadow-lg hover:shadow-xl transition-shadow duration-300">
        {navItems.map((item, index) => (
          <li class="nav-item">
            <a 
              href={item.href} 
              class={`nav-link relative px-5 py-2.5 rounded-full font-heading font-bold text-sm uppercase tracking-wide transition-all duration-300 ${
                Astro.url.pathname === item.href 
                  ? 'bg-primary text-white shadow-md' 
                  : 'text-primary hover:text-accent hover:bg-black/5'
              }`}
              style="animation-delay: ${index * 50}ms"
            >
              {item.name}
              {Astro.url.pathname === item.href && (
                <span class="absolute inset-0 rounded-full bg-primary opacity-20 animate-pulse"></span>
              )}
            </a>
          </li>
        ))}
      </ul>
      
      <!-- CTA Button -->
      <a href="/contacto" class="btn btn-accent btn-sm hover-lift shadow-lg hover:shadow-accent transition-all duration-300">
        Únete Ahora
      </a>
    </nav>

    <!-- Mobile Toggle -->
    <button 
      id="mobile-toggle" 
      class="lg:hidden bg-white/90 backdrop-blur-sm p-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110" 
      aria-label="Menú"
      aria-expanded="false"
    >
      <div class="hamburger flex flex-col gap-1.5">
        <span class="bar w-6 h-0.5 bg-primary rounded-full transition-all duration-300"></span>
        <span class="bar w-6 h-0.5 bg-primary rounded-full transition-all duration-300"></span>
        <span class="bar w-6 h-0.5 bg-primary rounded-full transition-all duration-300"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Nav Overlay -->
  <nav 
    id="mobile-nav" 
    class="mobile-nav fixed top-0 left-0 w-full h-screen bg-primary/95 backdrop-blur-2xl flex justify-center items-center opacity-0 pointer-events-none transition-all duration-500 z-modal"
    aria-hidden="true"
  >
    <div class="container relative">
      <!-- Close Button -->
      <button 
        id="mobile-close" 
        class="absolute top-4 right-4 bg-white/20 hover:bg-white/30 p-3 rounded-full transition-all duration-300"
        aria-label="Cerrar menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      
      <ul class="list-none text-center flex flex-col gap-6">
        {navItems.map((item, index) => (
          <li class="mobile-nav-item" style="animation-delay: ${index * 100}ms">
            <a 
              href={item.href} 
              class="mobile-nav-link font-heading text-4xl md:text-5xl font-bold text-white hover:text-highlight transition-all duration-300 hover:scale-110 inline-block"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
      
      <!-- Mobile CTA -->
      <div class="mt-12 text-center">
        <a href="/contacto" class="btn btn-highlight btn-lg inline-block">
          Únete Ahora
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Header States */
  .header.scrolled {
    padding-top: var(--spacing-3);
    padding-bottom: var(--spacing-3);
  }
  
  .header.scrolled .header-glass {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }
  
  .header.scrolled .logo-conquis {
    height: 45px;
  }
  
  .header.scrolled .logo-rigel {
    height: 55px;
  }
  
  /* Nav Link Hover Effects */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }
  
  .nav-link:hover::after {
    width: 80%;
  }
  
  /* Mobile Nav States */
  .mobile-nav.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  
  .mobile-nav.is-open .mobile-nav-item {
    animation: slideInUp 0.5s ease forwards;
    opacity: 0;
    transform: translateY(30px);
  }
  
  /* Hamburger Animation */
  .mobile-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  
  .mobile-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  
  .mobile-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }
  
  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileClose = document.getElementById('mobile-close');
  const header = document.getElementById('main-header');
  const mobileLinks = mobileNav?.querySelectorAll('.mobile-nav-link');
  
  // Toggle Mobile Menu
  const toggleMobileMenu = () => {
    const isOpen = mobileNav?.classList.toggle('is-open');
    mobileToggle?.setAttribute('aria-expanded', isOpen.toString());
    mobileNav?.setAttribute('aria-hidden', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };
  
  mobileToggle?.addEventListener('click', toggleMobileMenu);
  mobileClose?.addEventListener('click', toggleMobileMenu);
  
  // Close on link click
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      if (mobileNav?.classList.contains('is-open')) {
        toggleMobileMenu();
      }
    });
  });
  
  // Close on backdrop click
  mobileNav?.addEventListener('click', (e) => {
    if (e.target === mobileNav) {
      toggleMobileMenu();
    }
  });
  
  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileNav?.classList.contains('is-open')) {
      toggleMobileMenu();
    }
  });
  
  // Scroll Effect with Throttle
  let lastScrollY = window.scrollY;
  let ticking = false;
  
  const updateHeader = () => {
    const currentScrollY = window.scrollY;
    
    if (currentScrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
    
    // Hide/show on scroll direction
    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      header?.style.transform = 'translateY(-100%)';
    } else {
      header?.style.transform = 'translateY(0)';
    }
    
    lastScrollY = currentScrollY;
    ticking = false;
  };
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });
</script>
