---
import { Image } from 'astro:assets';
import rigelLogo from '../assets/rigel.png';
import conquisLogo from '../assets/conquis.svg';

const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Quienes somos', href: '/quienes-somos' },
  { name: 'Historia', href: '/historia' },
  { name: 'Recursos', href: '/recursos' },
  { name: 'Contacto', href: '/contacto' },
];
---

<header id="main-header" class="header fixed top-0 left-0 w-full z-sticky transition-all duration-300 py-8">
  <div class="container flex justify-between items-center">
    <a href="/" class="logo-link">
      <div class="flex items-center gap-4">
        <Image src={conquisLogo} alt="Conquistadores" class="h-[70px] w-auto drop-shadow-md transition-all duration-300" />
        <Image src={rigelLogo} alt="Club Rigel" class="h-[80px] w-auto drop-shadow-md transition-all duration-300" />
      </div>
    </a>

    <!-- Desktop Nav: Floating Pill -->
    <nav class="desktop-nav hidden lg:block">
      <ul class="glass-panel flex items-center gap-2 px-4 py-2 rounded-full list-none shadow-xl">
        {navItems.map(item => (
          <li>
            <a href={item.href} class={`nav-link px-5 py-2 rounded-full font-heading font-bold text-sm uppercase tracking-wide transition-all duration-200 ${Astro.url.pathname === item.href ? 'bg-primary text-white' : 'text-primary hover:text-accent hover:bg-black/5'}`}>
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile Toggle -->
    <button id="mobile-toggle" class="lg:hidden bg-white p-2.5 rounded-full shadow-md" aria-label="Menú">
      <div class="flex flex-col gap-1">
        <span class="w-6 h-0.5 bg-primary transition-all duration-300"></span>
        <span class="w-6 h-0.5 bg-primary transition-all duration-300"></span>
        <span class="w-6 h-0.5 bg-primary transition-all duration-300"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Nav Overlay -->
  <nav id="mobile-nav" class="mobile-nav fixed top-0 left-0 w-full h-screen bg-primary/98 backdrop-blur-xl flex justify-center items-center opacity-0 pointer-events-none transition-opacity duration-300 z-modal">
    <ul class="list-none text-center flex flex-col gap-8">
      {navItems.map(item => (
        <li><a href={item.href} class="mobile-nav-link font-heading text-5xl font-bold text-white">{item.name}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header.scrolled {
    padding-top: var(--spacing-4);
    padding-bottom: var(--spacing-4);
  }

  .header.scrolled img {
    height: 50px;
  }

  .header.scrolled img:first-child {
    height: 40px;
  }

  .mobile-nav.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const header = document.getElementById('main-header');

  mobileToggle?.addEventListener('click', () => {
    mobileNav?.classList.toggle('is-open');
    document.body.style.overflow = mobileNav?.classList.contains('is-open') ? 'hidden' : '';
  });

  mobileNav?.addEventListener('click', (e) => {
    if (e.target === mobileNav) {
      mobileNav.classList.remove('is-open');
      document.body.style.overflow = '';
    }
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
