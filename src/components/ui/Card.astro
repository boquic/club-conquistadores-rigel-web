---
interface Props {
  variant?: 'default' | 'primary' | 'accent' | 'glass' | 'glass-dark';
  padding?: 'sm' | 'md' | 'lg' | 'xl';
  hover?: boolean;
  class?: string;
}

const { 
  variant = 'default', 
  padding = 'lg',
  hover = true,
  class: className 
} = Astro.props;

const baseClasses = 'card bg-white rounded-xl shadow-md relative overflow-hidden';
const variantClasses = {
  default: 'bg-white',
  primary: 'card-primary bg-gradient-to-br from-primary to-primary/80 text-white',
  accent: 'card-accent bg-gradient-to-br from-accent to-accent/80 text-white',
  glass: 'glass-panel',
  'glass-dark': 'glass-dark'
};
const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
  xl: 'p-10'
};
const hoverClasses = hover ? 'hover-lift' : '';

const cardClasses = `${baseClasses} ${variantClasses[variant]} ${paddingClasses[padding]} ${hoverClasses} ${className || ''}`;
---

<div class={cardClasses}>
  <slot />
</div>
