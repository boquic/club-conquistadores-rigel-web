---
interface Props {
  date: string;
  title: string;
  active?: boolean;
  class?: string;
}

const { 
  date, 
  title, 
  active = false,
  class: className 
} = Astro.props;
---

<div class={`timeline-item relative pl-8 ${active ? 'active' : ''} ${className || ''}`}>
  <!-- Timeline Dot -->
  <div class="timeline-dot absolute -left-10 top-0 w-4 h-4 rounded-full border-2 border-white transition-all duration-300 ${active ? 'bg-accent scale-125 shadow-lg' : 'bg-accent/60'}"></div>
  
  <!-- Date -->
  <div class="timeline-date font-bold text-highlight mb-2 text-sm uppercase tracking-wide">
    {date}
  </div>
  
  <!-- Title -->
  <h3 class="timeline-title text-2xl text-primary font-bold mb-2">
    {title}
  </h3>
  
  <!-- Content -->
  <div class="timeline-content text-gray-600 leading-relaxed">
    <slot />
  </div>
</div>

<style>
  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    margin-bottom: 3rem;
  }
  
  .timeline-item:last-child {
    margin-bottom: 0;
  }
  
  .timeline-dot {
    transition: all var(--transition-base);
  }
  
  .timeline-item:hover .timeline-dot {
    transform: scale(1.25);
    box-shadow: 0 0 20px rgba(190, 22, 34, 0.4);
  }
  
  .timeline-item.active .timeline-dot {
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(190, 22, 34, 0.4);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(190, 22, 34, 0);
    }
  }
</style>
