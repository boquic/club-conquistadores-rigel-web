---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Historia">
  <section class="section container">
    <h1 class="text-5xl text-primary mb-12 font-bold">Nuestra Historia</h1>
    <div class="border-l-2 border-accent pl-8 flex flex-col gap-12">
      <div class="relative">
        <div class="absolute -left-10 top-0 w-4 h-4 bg-accent rounded-full border-2 border-white"></div>
        <div class="font-bold text-highlight mb-2">2010</div>
        <h3 class="text-2xl text-primary font-bold mb-2">Fundación</h3>
        <p>El Club Rigel abre sus puertas con 15 miembros iniciales.</p>
      </div>
      <div class="relative">
        <div class="absolute -left-10 top-0 w-4 h-4 bg-accent rounded-full border-2 border-white"></div>
        <div class="font-bold text-highlight mb-2">2015</div>
        <h3 class="text-2xl text-primary font-bold mb-2">Primer Camporee</h3>
        <p>Participación destacada en el Camporee Regional.</p>
      </div>
      <div class="relative">
        <div class="absolute -left-10 top-0 w-4 h-4 bg-accent rounded-full border-2 border-white"></div>
        <div class="font-bold text-highlight mb-2">2023</div>
        <h3 class="text-2xl text-primary font-bold mb-2">Actualidad</h3>
        <p>Hoy contamos con más de 50 conquistadores activos y diversas unidades.</p>
      </div>
    </div>
  </section>
</MainLayout>

