---
import MainLayout from '../layouts/MainLayout.astro';
import { Section } from '../components/ui/Section.astro';
import { Title } from '../components/ui/Title.astro';
import { TimelineItem } from '../components/ui/TimelineItem.astro';
import { Card } from '../components/ui/Card.astro';
import { Button } from '../components/ui/Button.astro';

const milestones = [
  {
    date: '2010',
    title: 'Fundación',
    description: 'El Club Rigel abre sus puertas con 15 miembros iniciales, con la visión de formar líderes y servir a la comunidad.',
    active: true
  },
  {
    date: '2012',
    title: 'Primera Investidura',
    description: 'Ceremonia inaugural donde los primeros conquistadores recibieron sus insignias y honores.',
    active: false
  },
  {
    date: '2015',
    title: 'Primer Camporee Regional',
    description: 'Participación destacada en el Camporee Regional, obteniendo reconocimientos en especialidades y drill.',
    active: false
  },
  {
    date: '2018',
    title: 'Expansión de Unidades',
    description: 'Creación de nuevas unidades: Amigos, Compañeros y Exploradores, atendiendo diferentes edades.',
    active: false
  },
  {
    date: '2020',
    title: 'Adaptación y Resiliencia',
    description: 'Innovación en actividades durante tiempos desafiantes, manteniendo el espíritu conquistador vivo.',
    active: false
  },
  {
    date: '2023',
    title: 'Actualidad',
    description: 'Hoy contamos con más de 50 conquistadores activos, directores comprometidos y un futuro brillante por delante.',
    active: false
  }
];

const values = [
  { icon: '⚜️', title: 'Honradez', desc: 'Actuamos con integridad en todo momento' },
  { icon: '🤝', title: 'Servicio', desc: 'Servimos a otros con amor y dedicación' },
  { icon: '🌟', title: 'Excelencia', desc: 'Buscamos la mejora continua en todo' },
  { icon: '❤️', title: 'Amistad', desc: 'Construimos lazos que duran toda la vida' }
];
---

<MainLayout title="Historia" description="Descubre la historia del Club Conquistadores Rigel, desde sus inicios hasta hoy.">
  <!-- Hero Section -->
  <Section background="dark" class="py-20">
    <div class="container text-center">
      <Title level={1} size="5xl" color="white" align="center" class="mb-6">
        Nuestra Historia
      </Title>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        Más de una década formando líderes, construyendo character y sirviendo a nuestra comunidad.
        Cada hito cuenta una historia de dedicación y pasión.
      </p>
    </div>
  </Section>
  
  <!-- Timeline Section -->
  <Section size="xl">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Nuestro Camino
        </Title>
        <p class="text-lg text-gray-600">
          Un viaje marcado por hitos significativos y momentos inolvidables
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="border-l-2 border-accent pl-8 flex flex-col gap-12">
          {milestones.map(milestone => (
            <TimelineItem 
              date={milestone.date} 
              title={milestone.title} 
              active={milestone.active}
            >
              {milestone.description}
            </TimelineItem>
          ))}
        </div>
      </div>
    </div>
  </Section>
  
  <!-- Values Section -->
  <Section background="gradient">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Nuestros Valores
        </Title>
        <p class="text-lg text-gray-600">
          Los principios que nos guían desde el primer día
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map(value => (
          <Card variant="glass" padding="lg" hover={true}>
            <div class="text-5xl mb-4">{value.icon}</div>
            <h3 class="text-xl text-primary font-bold mb-2">{value.title}</h3>
            <p class="text-gray-600 leading-relaxed">{value.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- CTA Section -->
  <Section size="lg">
    <div class="container text-center">
      <div class="glass-panel max-w-3xl mx-auto p-12 rounded-2xl">
        <Title level={2} size="3xl" color="primary" align="center" class="mb-4">
          Sé Parte de Nuestra Historia
        </Title>
        <p class="text-lg text-gray-600 mb-8">
          Cada conquistador escribe su propio capítulo en la historia del Club Rigel.
          ¿Listo para comenzar el tuyo?
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <Button href="/contacto" variant="accent" size="lg" icon="🚀">
            Únete Ahora
          </Button>
          <Button href="/quienes-somos" variant="outline" size="lg">
            Conoce Más
          </Button>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

