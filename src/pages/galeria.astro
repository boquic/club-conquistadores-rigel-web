---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/ui/Section.astro';
import Title from '../components/ui/Title.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';

const categories = [
  { name: 'Campamentos', icon: '⛺', count: 24 },
  { name: 'Servicio', icon: '🤝', count: 18 },
  { name: 'Especialidades', icon: '🏅', count: 32 },
  { name: 'Eventos', icon: '🎉', count: 15 }
];

const galleryItems = Array.from({ length: 12 }, (_, i) => ({
  id: i + 1,
  category: categories[i % categories.length].name,
  placeholder: true
}));
---

<MainLayout title="Galería" description="Galería de fotos del Club Conquistadores Rigel: campamentos, actividades, eventos y momentos especiales.">
  <!-- Hero Section -->
  <Section background="dark" class="py-20">
    <div class="container text-center">
      <Title level={1} size="5xl" color="white" align="center" class="mb-6">
        Galería de Fotos
      </Title>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        Momentos inolvidables capturados en imagen. Cada foto cuenta una historia de aventura, 
        amistad y crecimiento en el Club Rigel.
      </p>
    </div>
  </Section>
  
  <!-- Categories Section -->
  <Section size="lg">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map(category => (
          <Card variant="glass" padding="md" hover={true} class="text-center cursor-pointer">
            <div class="text-4xl mb-2">{category.icon}</div>
            <h3 class="text-lg text-primary font-bold">{category.name}</h3>
            <div class="text-sm text-gray-500">{category.count} fotos</div>
          </Card>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- Gallery Grid -->
  <Section size="xl">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Nuestros Momentos
        </Title>
        <p class="text-lg text-gray-600">
          Explora nuestra colección de recuerdos y aventuras
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {galleryItems.map((item, index) => (
          <div 
            class={`aspect-square rounded-xl overflow-hidden relative group cursor-pointer ${
              index === 0 ? 'md:col-span-2 md:row-span-2' : ''
            }`}
          >
            <div class="w-full h-full bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center pulse">
              <div class="text-center">
                <div class="text-4xl mb-2">📸</div>
                <div class="text-sm text-gray-500">{item.category}</div>
              </div>
            </div>
            <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white font-semibold">Ver foto</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- CTA Section -->
  <Section size="lg">
    <div class="container text-center">
      <div class="glass-panel max-w-3xl mx-auto p-12 rounded-2xl">
        <Title level={2} size="3xl" color="primary" align="center" class="mb-4">
          ¿Quieres Aparecer Aquí?
        </Title>
        <p class="text-lg text-gray-600 mb-8">
          Únete a nuestras actividades y sé parte de los próximos momentos que capturaremos.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <Button href="/contacto" variant="accent" size="lg" icon="🚀">
            Únete Ahora
          </Button>
          <Button href="/actividades" variant="outline" size="lg">
            Ver Actividades
          </Button>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

