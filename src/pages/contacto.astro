---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contacto">
  <section class="section container">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h1 class="text-5xl text-primary mb-4 font-bold">Contáctanos</h1>
        <p class="mb-8">
          ¿Tienes preguntas? ¡Queremos escucharte!
          Escríbenos y nos pondremos en contacto contigo lo antes posible.
        </p>
        <div class="mb-4">
          <strong class="font-semibold">Email:</strong> info@olubrigel.com
        </div>
        <div class="mb-4">
          <strong class="font-semibold">Dirección:</strong> Iglesia Central, Ciudad
        </div>
      </div>

      <form class="glass-panel p-8 rounded-xl">
        <div class="input-group">
          <label for="name" class="input-label">Nombre</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="input-group">
          <label for="email" class="input-label">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="input-group">
          <label for="message" class="input-label">Mensaje</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-accent w-full">Enviar Mensaje</button>
      </form>
    </div>
  </section>
</MainLayout>

