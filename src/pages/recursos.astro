---
import MainLayout from '../layouts/MainLayout.astro';
import { Section } from '../components/ui/Section.astro';
import { Title } from '../components/ui/Title.astro';
import { Card } from '../components/ui/Card.astro';
import { Button } from '../components/ui/Button.astro';

const resources = [
  {
    icon: '📘',
    title: 'Manual Administrativo',
    description: 'Guía completa para directores y líderes del club. Procedimientos, normas y mejores prácticas.',
    category: 'Administración',
    size: 'PDF'
  },
  {
    icon: '📝',
    title: 'Ficha Médica',
    description: 'Formulario de información médica obligatoria para todos los conquistadores. Requisito para actividades.',
    category: 'Formularios',
    size: 'PDF'
  },
  {
    icon: '📅',
    title: 'Calendario 2026',
    description: 'Planificación anual de actividades, campamentos y eventos especiales del Club Rigel.',
    category: 'Planificación',
    size: 'PDF'
  },
  {
    icon: '🏅',
    title: 'Guía de Especialidades',
    description: 'Catálogo completo de especialidades disponibles con requisitos y actividades.',
    category: 'Especialidades',
    size: 'PDF'
  },
  {
    icon: '🎯',
    title: 'Ley del Conquistador',
    description: 'Los principios y valores que cada conquistador debe conocer y practicar.',
    category: 'Formación',
    size: 'PDF'
  },
  {
    icon: '📋',
    title: 'Lista de Útiles',
    description: 'Equipamiento y materiales necesarios para campamentos y actividades al aire libre.',
    category: 'Logística',
    size: 'PDF'
  }
];

const categories = ['Todos', 'Administración', 'Formularios', 'Planificación', 'Especialidades', 'Formación', 'Logística'];
---

<MainLayout title="Recursos" description="Recursos y documentos del Club Conquistadores Rigel: manuales, formularios, calendarios y guías.">
  <!-- Hero Section -->
  <Section background="dark" class="py-20">
    <div class="container text-center">
      <Title level={1} size="5xl" color="white" align="center" class="mb-6">
        Recursos
      </Title>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        Documentos, guías y materiales para directores, padres y conquistadores.
        Todo lo que necesitas para estar informado y preparado.
      </p>
    </div>
  </Section>
  
  <!-- Categories Filter -->
  <Section size="lg">
    <div class="container">
      <div class="flex flex-wrap gap-2 justify-center">
        {categories.map(category => (
          <Button 
            variant={category === 'Todos' ? 'accent' : 'outline'} 
            size="sm"
            class={category === 'Todos' ? '' : 'border-gray-300 text-gray-600 hover:border-primary hover:text-primary'}
          >
            {category}
          </Button>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- Resources Grid -->
  <Section size="xl">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Documentos Disponibles
        </Title>
        <p class="text-lg text-gray-600">
          Descarga los recursos que necesitas
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {resources.map(resource => (
          <Card variant="glass" padding="lg" hover={true}>
            <div class="flex items-start gap-4">
              <div class="text-4xl">{resource.icon}</div>
              <div class="flex-1">
                <h3 class="text-lg text-primary font-bold mb-2">{resource.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed mb-3">{resource.description}</p>
                <div class="flex items-center gap-2 text-xs text-gray-500">
                  <span class="bg-light px-2 py-1 rounded">{resource.category}</span>
                  <span class="bg-light px-2 py-1 rounded">{resource.size}</span>
                </div>
              </div>
            </div>
            <Button href="#" variant="ghost" size="sm" class="w-full mt-4 text-primary hover:text-accent">
              Descargar →
            </Button>
          </Card>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- Info Section -->
  <Section background="gradient">
    <div class="container">
      <div class="glass-panel max-w-3xl mx-auto p-12 rounded-2xl text-center">
        <Title level={2} size="3xl" color="primary" align="center" class="mb-4">
          ¿Necesitas Ayuda?
        </Title>
        <p class="text-lg text-gray-600 mb-8">
          Si no encuentras el recurso que buscas o tienes preguntas sobre los documentos,
          no dudes en contactarnos. Estamos aquí para ayudarte.
        </p>
        <Button href="/contacto" variant="accent" size="lg" icon="💬">
          Contáctanos
        </Button>
      </div>
    </div>
  </Section>
</MainLayout>

