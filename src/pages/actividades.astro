---
import MainLayout from '../layouts/MainLayout.astro';
import SectionCard from '../components/SectionCard.astro';
---

<MainLayout title="Actividades">
  <section class="section container">
    <h1 class="text-5xl text-primary mb-12 font-bold">Actividades y Eventos</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <SectionCard title="Campamentos" icon="⛺">
        <p>Experiencias inolvidables en contacto con la naturaleza.</p>
      </SectionCard>
      <SectionCard title="Servicio Comunitario" icon="🤝">
        <p>Limpieza de parques, visitas a asilos y recolección de alimentos.</p>
      </SectionCard>
      <SectionCard title="Especialidades" icon="🏅">
        <p>Desarrollo de habilidades técnicas, manuales y recreativas.</p>
      </SectionCard>
      <SectionCard title="Investiduras" icon="🧣">
        <p>Reconocimiento al avance y logros de cada conquistador.</p>
      </SectionCard>
    </div>
  </section>
</MainLayout>

