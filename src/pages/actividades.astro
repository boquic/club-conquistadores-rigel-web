---
import MainLayout from '../layouts/MainLayout.astro';
import { Section } from '../components/ui/Section.astro';
import { Title } from '../components/ui/Title.astro';
import { Card } from '../components/ui/Card.astro';
import { Button } from '../components/ui/Button.astro';

const activities = [
  {
    icon: '⛺',
    title: 'Campamentos',
    description: 'Experiencias inolvidables en contacto con la naturaleza. Noches bajo las estrellas, fogatas y aventuras al aire libre.',
    featured: true
  },
  {
    icon: '🤝',
    title: 'Servicio Comunitario',
    description: 'Limpieza de parques, visitas a asilos, recolección de alimentos y proyectos que transforman comunidades.',
    featured: false
  },
  {
    icon: '🏅',
    title: 'Especialidades',
    description: 'Desarrollo de habilidades técnicas, manuales y recreativas. Más de 300 especialidades para explorar.',
    featured: false
  },
  {
    icon: '🧣',
    title: 'Investiduras',
    description: 'Ceremonias especiales donde reconocemos el avance y logros de cada conquistador en su camino.',
    featured: false
  },
  {
    icon: '🏃',
    title: 'Drill y Marcha',
    description: 'Disciplina, trabajo en equipo y coordinación a través de formaciones y desfiles.',
    featured: false
  },
  {
    icon: '🎨',
    title: 'Artes y Manualidades',
    description: 'Creatividad y expresión artística mediante proyectos manuales y artísticos.',
    featured: false
  },
  {
    icon: '🌲',
    title: 'Excursiones',
    description: 'Exploración de senderos, montañas y lugares naturales para aprender sobre el medio ambiente.',
    featured: false
  },
  {
    icon: '🎪',
    title: 'Eventos Especiales',
    description: 'Días de campo, olimpiadas, festivales y celebraciones que crean recuerdos inolvidables.',
    featured: false
  }
];

const upcomingEvents = [
  { name: 'Campamento de Verano', date: 'Enero 2026', icon: '☀️' },
  { name: 'Camporee Regional', date: 'Marzo 2026', icon: '🏕️' },
  { name: 'Día de Campo', date: 'Abril 2026', icon: '🎉' }
];
---

<MainLayout title="Actividades" description="Descubre las actividades y eventos del Club Conquistadores Rigel: campamentos, servicio, especialidades y más.">
  <!-- Hero Section -->
  <Section background="dark" class="py-20">
    <div class="container text-center">
      <Title level={1} size="5xl" color="white" align="center" class="mb-6">
        Actividades y Eventos
      </Title>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        Aventuras, aprendizaje y servicio. Cada actividad es una oportunidad para crecer, 
        hacer amigos y crear recuerdos que duran toda la vida.
      </p>
    </div>
  </Section>
  
  <!-- Featured Activities -->
  <Section size="xl">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Nuestras Actividades
        </Title>
        <p class="text-lg text-gray-600">
          Experiencias diseñadas para el desarrollo integral de cada conquistador
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {activities.map((activity, index) => (
          <Card 
            variant={activity.featured ? 'accent' : 'glass'} 
            padding="lg" 
            hover={true}
            class={activity.featured ? 'md:col-span-2 lg:col-span-2' : ''}
          >
            <div class={activity.featured ? 'text-white' : ''}>
              <div class="text-5xl mb-4">{activity.icon}</div>
              <h3 class="text-xl font-bold mb-3">{activity.title}</h3>
              <p class="leading-relaxed text-sm opacity-90">{activity.description}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- Upcoming Events -->
  <Section background="gradient">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <Title level={2} size="4xl" color="primary" align="center" class="mb-4">
          Próximos Eventos
        </Title>
        <p class="text-lg text-gray-600">
          No te pierdas nuestras próximas aventuras
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {upcomingEvents.map(event => (
          <Card variant="glass" padding="lg" hover={true}>
            <div class="text-center">
              <div class="text-4xl mb-3">{event.icon}</div>
              <h3 class="text-lg text-primary font-bold mb-2">{event.name}</h3>
              <div class="text-accent font-semibold">{event.date}</div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- CTA Section -->
  <Section size="lg">
    <div class="container text-center">
      <div class="glass-panel max-w-3xl mx-auto p-12 rounded-2xl">
        <Title level={2} size="3xl" color="primary" align="center" class="mb-4">
          ¿Listo para la Aventura?
        </Title>
        <p class="text-lg text-gray-600 mb-8">
          Únete a nuestras actividades y comienza a crear tu propia historia de aventuras.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <Button href="/contacto" variant="accent" size="lg" icon="🚀">
            Únete Ahora
          </Button>
          <Button href="/historia" variant="outline" size="lg">
            Nuestra Historia
          </Button>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>

